# Backend
RESPINET_HOST=127.0.0.1
RESPINET_PORT=5000
RESPINET_MODEL_PATH=artifacts/latest/best_model.keras
RESPINET_MODEL_METADATA=artifacts/latest/model_metadata.json
RESPINET_DATASET_DIR=dataset/ICBHI_final_dataset
RESPINET_DIAGNOSIS_CSV=patient_diagnosis.csv
RESPINET_MAX_UPLOAD_MB=25
RESPINET_MAX_AUDIO_SECONDS=120
RESPINET_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Set to 1 for any non-local deployment.
RESPINET_REQUIRE_METADATA=0
RESPINET_SOURCE_REVISION=replace-with-git-commit

# Optional external LLM. Do not put a real key in source control.
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.1-8b-instant
GROQ_DEBUG=0

# React frontend; empty uses same-origin requests and the Vite development proxy.
VITE_API_BASE_URL=
